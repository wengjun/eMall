# Minimal local defaults for running a few Spring Boot modules directly.
# Docker Compose container-network defaults live in ops/env/local.env.
EMALL_DB_USERNAME=root
EMALL_DB_PASSWORD=root
EMALL_REDIS_HOST=localhost
EMALL_REDIS_PORT=6379
EMALL_NACOS_SERVER_ADDR=localhost:8848
EMALL_NACOS_DISCOVERY_ENABLED=false
EMALL_NACOS_CONFIG_ENABLED=false
EMALL_RPC_PROTOCOL=http
EMALL_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
EMALL_ELASTICSEARCH_URL=http://localhost:9200
EMALL_CLICKHOUSE_URL=jdbc:clickhouse://localhost:8123/emall
EMALL_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
EMALL_INTERNAL_OPERATIONS_TOKEN=local-dev-token
EMALL_FIELD_ENCRYPTION_KEY=replace-with-32-byte-or-longer-production-key
