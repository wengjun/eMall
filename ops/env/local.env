# Local Docker Compose defaults only. Do not use these values in production.
EMALL_NACOS_SERVER_ADDR=nacos:8848
EMALL_NACOS_DISCOVERY_ENABLED=true
EMALL_NACOS_CONFIG_ENABLED=false
EMALL_DB_USERNAME=root
EMALL_DB_PASSWORD=root
EMALL_FIELD_ENCRYPTION_KEY=local-development-field-encryption-key
EMALL_INTERNAL_OPERATIONS_TOKEN=local-dev-token
EMALL_REDIS_HOST=redis
EMALL_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
EMALL_ELASTICSEARCH_URL=http://elasticsearch:9200
EMALL_CLICKHOUSE_URL=jdbc:clickhouse://clickhouse:8123/emall
EMALL_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
EMALL_RPC_PROTOCOL=dubbo
EMALL_DUBBO_REGISTRY_ADDRESS=nacos://nacos:8848
EMALL_DUBBO_PORT=-1
